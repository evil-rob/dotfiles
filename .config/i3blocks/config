# i3blocks configuration file for swaybar

# Global properties
separator_block_width=50

# Display window name
[window]
command=swaymsg -mt subscribe '["window","workspace"]' | "$SCRIPTS/$BLOCK_NAME.jq"
format=json
interval=persist

# Weather widget
[weather]
command="$SCRIPTS/weather.sh"
interval=once
signal=10
#color=#87CEEB

# Network widget
[network]
label= 
command="$SCRIPTS/network.sh"
interval=5

# Battery indicator
[battery]
command="$SCRIPTS/battery.sh"
interval=10

# Package updates
[updates]
label= 
command="$SCRIPTS/updates.sh"
interval=once
signal=10

# Clock
[time]
label= 
command=date '+%m/%d/%Y  %I:%M %p'
interval=30
